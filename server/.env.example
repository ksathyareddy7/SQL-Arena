# PostgreSQL connection
#
# This repo supports both:
# - Local Postgres (commonly on 5432)
# - Docker Postgres (default 5433 to avoid overlapping with local Postgres)
#
# The runtime server connection is controlled via `SQL_ARENA_DB_MODE`.

DB_HOST=localhost
DB_PORT=5432
DB_NAME=sql_arena
DB_USER=postgres
DB_PASSWORD=postgres

# Docker Postgres (used by `node setup.js --mode docker`)
DOCKER_DB_HOST=127.0.0.1
DOCKER_DB_PORT=5433
DOCKER_DB_NAME=sql_arena
DOCKER_DB_USER=postgres
DOCKER_DB_PASSWORD=postgres

# Server DB mode:
# - local  => uses DB_*
# - docker => uses DOCKER_DB_*
SQL_ARENA_DB_MODE=local

# Server
PORT=3000
